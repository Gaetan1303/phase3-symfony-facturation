{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block stylesheets %}
  <script src="https://cdn.tailwindcss.com"></script>
{% endblock %}

{% block body %}

    <!-- Main content -->
    <section class="flex-1 p-8">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-6">
          <h1 class="text-2xl font-bold text-gray-900">Tableau de bord</h1>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
          <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
            <div class="flex items-start justify-between">
              <div class="flex items-center gap-3">
                <div class="p-2 bg-blue-50 rounded-md text-blue-600">
                  <!-- icon -->
                </div>
                <div>
                  <div class="text-sm text-gray-500">Chiffre d'affaires (Payé)</div>
                </div>
              </div>
            </div>
            <div class="mt-3 text-2xl font-semibold text-gray-900">{{ summary.totalRevenue|number_format(0, ',', ' ') }} €</div>
          </div>

          <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
            <div class="text-sm text-gray-500">Factures en attente</div>
            <div class="mt-3 text-2xl font-semibold text-gray-900">{{ summary.invoicesCount }}</div>
          </div>

          <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
            <div class="text-sm text-gray-500">Clients</div>
            <div class="mt-3 text-2xl font-semibold text-gray-900">{{ summary.clientsCount }}</div>
          </div>

          <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
            <div class="text-sm text-gray-500">Produits</div>
            <div class="mt-3 text-2xl font-semibold text-gray-900">{{ summary.productsCount }}</div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2 bg-white border border-gray-100 rounded-xl p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-medium text-gray-900">Chiffre d'affaires</h2>
              <form method="get" class="flex items-center gap-3">
                <select name="period" class="rounded border px-2 py-1" onchange="this.form.requestSubmit()">
                  <option value="monthly" {{ period == 'monthly' ? 'selected' : '' }}>Mensuel</option>
                  <option value="yearly" {{ period == 'yearly' ? 'selected' : '' }}>Annuel</option>
                </select>
                {% if period == 'monthly' %}
                  <select name="year" class="rounded border px-2 py-1" onchange="this.form.requestSubmit()">
                    {% set yrs = availableYears is defined and availableYears ? availableYears : [year] %}
                    {% for y in yrs %}
                      <option value="{{ y }}" {{ y == year ? 'selected' : '' }}>{{ y }}</option>
                    {% endfor %}
                  </select>
                {% endif %}
              </form>
            </div>

            <div class="w-full">
              <div class="w-full h-80" data-controller="revenue-chart" data-revenue-chart-labels-value='{{ chart.labels|json_encode|raw }}' data-revenue-chart-data-value='{{ chart.data|json_encode|raw }}'>
                <canvas id="revenueChart" class="w-full h-full"></canvas>
              </div>
            </div>
          </div>

          <div class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm">
            <h2 class="text-lg font-medium text-gray-900 mb-4">Actions rapides</h2>
            <div class="space-y-3">
              <a href="#" class="block px-4 py-3 bg-blue-50 text-blue-700 rounded-md">Créer une facture</a>
              <a href="#" class="block px-4 py-3 bg-gray-50 text-gray-700 rounded-md">Ajouter un client</a>
              <a href="{{ path('product_new') }}" class="block px-4 py-3 bg-gray-50 text-gray-700 rounded-md">Créer un produit / service</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  {# Load a specific Chart.js UMD build and initialize chart on Turbo navigation #}
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  {# Chart initialization handled by Stimulus controller `revenue_chart_controller.js` #}
{% endblock %}
