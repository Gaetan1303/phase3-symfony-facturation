{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block stylesheets %}
  {% include 'components/_dashboard_styles.html.twig' %}
{% endblock %}

{% block body %}
  <main class="dashboard-page">
    <div class="dashboard-layout">
      <aside class="dashboard-sidebar">
        <div class="dashboard-brand">
          <div class="dashboard-brand-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 3V21L6.4 19.8L8.8 21L11.2 19.8L13.6 21L16 19.8L18.4 21L20 20.2V3L17.6 4.2L15.2 3L12.8 4.2L10.4 3L8 4.2L5.6 3L4 3Z" stroke="#155DFC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15.5 8H10.5C9.67 8 9 8.67 9 9.5C9 10.33 9.67 11 10.5 11H13.5C14.33 11 15 11.67 15 12.5C15 13.33 14.33 14 13.5 14H8.5" stroke="#155DFC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 6.5V15.5" stroke="#155DFC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="dashboard-brand-text">FacturSaaS</div>
        </div>

        <nav class="dashboard-navigation" aria-label="Navigation principale">
          <a class="dashboard-link is-active" href="{{ path('app_dashboard') }}">
            <span class="dashboard-link-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="3" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.6"/>
                <rect x="12" y="3" width="5" height="3" rx="1" stroke="currentColor" stroke-width="1.6"/>
                <rect x="12" y="9" width="5" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                <rect x="3" y="12" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.6"/>
              </svg>
            </span>
            <span>Dashboard</span>
          </a>
          <a class="dashboard-link" href="#">
            <span class="dashboard-link-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 3.5H12L15 6.5V16.5H5V3.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                <path d="M12 3.5V6.5H15" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                <path d="M8 9.5H12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                <path d="M8 12.5H12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </span>
            <span>Factures</span>
          </a>
          <a class="dashboard-link" href="#">
            <span class="dashboard-link-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6.5 9C8.15685 9 9.5 7.65685 9.5 6C9.5 4.34315 8.15685 3 6.5 3C4.84315 3 3.5 4.34315 3.5 6C3.5 7.65685 4.84315 9 6.5 9Z" stroke="currentColor" stroke-width="1.6"/>
                <path d="M13.5 10C15.1569 10 16.5 8.65685 16.5 7C16.5 5.34315 15.1569 4 13.5 4C11.8431 4 10.5 5.34315 10.5 7C10.5 8.65685 11.8431 10 13.5 10Z" stroke="currentColor" stroke-width="1.6"/>
                <path d="M2.5 16C2.5 13.7909 4.29086 12 6.5 12H8.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                <path d="M10.5 16C10.5 13.7909 12.2909 12 14.5 12H15.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </span>
            <span>Clients</span>
          </a>
          <a class="dashboard-link" href="#">
            <span class="dashboard-link-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 2.75L16 6.25V13.75L10 17.25L4 13.75V6.25L10 2.75Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                <path d="M10 2.75V17.25" stroke="currentColor" stroke-width="1.6"/>
                <path d="M4 6.25L16 13.75" stroke="currentColor" stroke-width="1.6"/>
              </svg>
            </span>
            <span>Produits</span>
          </a>
          <a class="dashboard-link" href="#">
            <span class="dashboard-link-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 10C11.6569 10 13 8.65685 13 7C13 5.34315 11.6569 4 10 4C8.34315 4 7 5.34315 7 7C7 8.65685 8.34315 10 10 10Z" stroke="currentColor" stroke-width="1.6"/>
                <path d="M4.5 16C4.5 13.5147 6.51472 11.5 9 11.5H11C13.4853 11.5 15.5 13.5147 15.5 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </span>
            <span>Profil</span>
          </a>
        </nav>

        <div class="dashboard-sidebar-footer">
          <div class="dashboard-user-row">
            <div class="dashboard-user-avatar">
              {{ ((app.user.firstName|default('J')|slice(0, 1)) ~ (app.user.lastName|default('D')|slice(0, 1)))|upper }}
            </div>
            <div class="dashboard-user-meta">
              <div class="dashboard-user-name">{{ app.user.companyName|default('Tech Solutions') }}</div>
              <div class="dashboard-user-email">{{ app.user.email|default('contact@entreprise.fr') }}</div>
            </div>
          </div>

          <a class="dashboard-logout" href="{{ path('app_logout') }}">
            <span class="dashboard-link-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 5H4V15H8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M11 10H17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                <path d="M14 7L17 10L14 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span>Déconnexion</span>
          </a>
        </div>
      </aside>

      <section class="dashboard-main-content">
        <div class="dashboard-shell">
          <h1 class="dashboard-heading">Dashboard</h1>

          <section class="dashboard-stats">
            <article class="dashboard-stat-card">
              <div class="dashboard-stat-icon dashboard-stat-icon-green">
                <span>EUR</span>
              </div>
              <div class="dashboard-stat-label">Chiffre d'affaires (Payé)</div>
              <div class="dashboard-stat-value">{{ summary.totalRevenue|number_format(0, ',', ' ') }} €</div>
            </article>

            <article class="dashboard-stat-card">
              <div class="dashboard-stat-icon dashboard-stat-icon-orange">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7 3.5H14L18 7.5V20.5H7V3.5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  <path d="M14 3.5V7.5H18" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  <path d="M10 11H15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M10 15H15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="dashboard-stat-label">Factures en attente de paiement</div>
              <div class="dashboard-stat-value">{{ summary.invoicesCount }}</div>
            </article>

            <article class="dashboard-stat-card">
              <div class="dashboard-stat-icon dashboard-stat-icon-blue">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 11C10.2091 11 12 9.20914 12 7C12 4.79086 10.2091 3 8 3C5.79086 3 4 4.79086 4 7C4 9.20914 5.79086 11 8 11Z" stroke="currentColor" stroke-width="1.8"/>
                  <path d="M16.5 12C18.433 12 20 10.433 20 8.5C20 6.567 18.433 5 16.5 5C14.567 5 13 6.567 13 8.5C13 10.433 14.567 12 16.5 12Z" stroke="currentColor" stroke-width="1.8"/>
                  <path d="M3.5 20C3.5 17.5147 5.51472 15.5 8 15.5H10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M13 20C13 17.7909 14.7909 16 17 16H19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="dashboard-stat-label">Total Clients</div>
              <div class="dashboard-stat-value">{{ summary.clientsCount }}</div>
            </article>

            <article class="dashboard-stat-card">
              <div class="dashboard-stat-icon dashboard-stat-icon-purple">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 3L19 7V17L12 21L5 17V7L12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  <path d="M12 3V21" stroke="currentColor" stroke-width="1.8"/>
                </svg>
              </div>
              <div class="dashboard-stat-label">Total Produits</div>
              <div class="dashboard-stat-value">{{ summary.productsCount }}</div>
            </article>
          </section>

          <section class="dashboard-chart-card">
            <div class="dashboard-chart-head">
              <h2>Chiffre d'affaires mensuel (Factures payées)</h2>
              <div class="dashboard-chart-year">2026</div>
            </div>

            <div class="dashboard-chart">
              <div class="dashboard-chart-y-axis">
                <span>2400€</span>
                <span>1800€</span>
                <span>1200€</span>
                <span>600€</span>
                <span>0€</span>
              </div>
              <div class="dashboard-chart-plot">
                <div class="dashboard-chart-grid"></div>
                <div class="dashboard-chart-bars">
                  {% set chartHeight = summary.totalRevenue > 0 ? 77 : 0 %}
                  {% for month in ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Juin', 'Juil', 'Aoû', 'Sep', 'Oct', 'Nov', 'Déc'] %}
                    <div class="dashboard-chart-month-column">
                      {% if month == 'Mar' and summary.totalRevenue > 0 %}
                        <div class="dashboard-chart-bar" style="height: {{ chartHeight }}%;"></div>
                      {% else %}
                        <div class="dashboard-chart-bar dashboard-chart-bar-empty"></div>
                      {% endif %}
                      <span>{{ month }}</span>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          </section>

          <section class="dashboard-actions">
            <a class="dashboard-action dashboard-action-primary" href="#">
              <div>
                <strong>Créer une facture</strong>
                <span>Nouvelle prestation</span>
              </div>
              <span class="dashboard-action-arrow">→</span>
            </a>
            <a class="dashboard-action" href="#">
              <div>
                <strong>Ajouter un client</strong>
                <span>Gérer le répertoire</span>
              </div>
              <span class="dashboard-action-arrow">→</span>
            </a>
            <a class="dashboard-action" href="#">
              <div>
                <strong>Créer un produit / service</strong>
                <span>Enrichir le catalogue pour rédiger rapidement vos factures</span>
              </div>
              <span class="dashboard-action-arrow">→</span>
            </a>
            <a class="dashboard-action" href="#">
              <div>
                <strong>Relancer tous les clients</strong>
                <span>Envoyer un mail à tous les clients en retard de paiement</span>
              </div>
              <span class="dashboard-action-arrow">→</span>
            </a>
          </section>
        </div>
      </section>
    </div>
  </main>
{% endblock %}
