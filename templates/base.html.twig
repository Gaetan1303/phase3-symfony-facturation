<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            <link href="https://fonts.googleapis.com/css2?family=Arimo:wght@400;700&display=swap" rel="stylesheet">
            <script src="https://cdn.tailwindcss.com"></script>
            <style>body{font-family: 'Arimo', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;}</style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <div class="min-h-screen bg-gray-50 flex">
            {% block sidebar %}{% include 'components/sidebar.html.twig' %}{% endblock %}

            <div class="flex-1" data-controller="confirm">
                                                                {% block body %}{% endblock %}

                                                                {# Inline flash banners (in addition to toasts) #}
                                                                {% if app.flashes %}
                                                                    <div class="max-w-4xl mx-auto px-4 py-4">
                                                                        {% for type, messages in app.flashes %}
                                                                            {% for msg in messages %}
                                                                                <div class="mb-3 p-3 rounded border {{ type == 'success' ? 'bg-green-50 border-green-200 text-green-800' : type == 'error' ? 'bg-red-50 border-red-200 text-red-800' : 'bg-gray-50 border-gray-200 text-gray-800' }}">
                                                                                    {{ msg }}
                                                                                </div>
                                                                            {% endfor %}
                                                                        {% endfor %}
                                                                    </div>
                                                                {% endif %}

                                                                <!-- Toast container for Turbo messages -->
                                <div id="toasts" class="fixed top-4 right-4 z-50 space-y-2"></div>
                                                                {# Confirm modal used for replacement of native confirm() #}
                                                                {% include 'components/confirm_modal.html.twig' %}
                                <script>
                                    // Simple toast auto-dismiss behavior
                                    (function(){
                                        window.showToast = function(html, timeout = 3500){
                                            const container = document.getElementById('toasts');
                                            if (!container) return;
                                            const wrapper = document.createElement('div');
                                            wrapper.innerHTML = html;
                                            const toast = wrapper.firstElementChild;
                                            if (!toast) return;
                                            toast.classList.add('opacity-0','transform','translate-y-2','transition','duration-200');
                                            container.appendChild(toast);
                                            // force reflow
                                            void toast.offsetWidth;
                                            toast.classList.remove('opacity-0','translate-y-2');
                                            // auto remove
                                            setTimeout(() => {
                                                toast.classList.add('opacity-0','translate-y-2');
                                                setTimeout(() => toast.remove(), 300);
                                            }, timeout);
                                        };
                                    })();
                                </script>
                                                                {# Render Symfony flash messages as toasts on full page load #}
                                                                {% if app.flashes %}
                                                                    <script>
                                                                        document.addEventListener('DOMContentLoaded', function(){
                                                                            {% for type, messages in app.flashes %}
                                                                                {% for msg in messages %}
                                                                                    showToast({{ include('turbo/inline_toast.html.twig', {'type': type, 'message': msg}) | json_encode | raw }});
                                                                                {% endfor %}
                                                                            {% endfor %}
                                                                        });
                                                                    </script>
                                                                {% endif %}
            </div>
        </div>
    </body>
</html>
