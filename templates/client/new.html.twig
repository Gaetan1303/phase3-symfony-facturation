{% extends 'base.html.twig' %}

{% block title %}Ajouter un client{% endblock %}

{% block stylesheets %}
  <script src="https://cdn.tailwindcss.com"></script>
{% endblock %}

{% block body %}
  <main class="min-h-screen bg-gray-50 flex">
    {# Sidebar component include #}
    {% include 'components/sidebar.html.twig' %}

    <!-- Client creation content (Figma-style modal card) -->
    <section class="flex-1 min-w-0">
      <!-- Mobile header -->
      <div class="md:hidden flex items-center gap-3 p-4 bg-white border-b border-[#E5E7EB]">
        <button id="sidebar-toggle" class="p-2 rounded-md text-[#4A5565] hover:bg-gray-100">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <span class="font-semibold text-[#101828]">Ajouter un client</span>
      </div>

      <div class="p-4 md:p-8 w-full flex flex-col items-center gap-8">
        <h2 class="text-center text-lg font-semibold uppercase tracking-wide text-[#101828]/80">Ajouter un nouveau client</h2>

        <div class="bg-white rounded-[14px] border border-[#F3F4F6] shadow-md p-6 w-full max-w-lg">
          <div class="mb-4">
            <h3 class="text-xl font-bold text-[#101828]">Nouveau client</h3>
          </div>

          {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}

            <div>
              <label class="block text-sm font-medium text-[#364153]">Nom du client / Entreprise</label>
              <div class="mt-2">
                {{ form_widget(form.name, {'attr': {'class': 'w-full rounded-md border border-[#D1D5DC] h-10 px-3 text-sm text-[#101828] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#EFF6FF] focus:border-[#155DFC]', 'placeholder': 'Ex: ACME Corp'}}) }}
              </div>
              {{ form_errors(form.name) }}
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-[#364153]">Email</label>
                <div class="mt-2">
                  {{ form_widget(form.email, {'attr': {'class': 'w-full rounded-md border border-[#D1D5DC] h-10 px-3 text-sm text-[#101828] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#EFF6FF] focus:border-[#155DFC]', 'placeholder': 'contact@example.com'}}) }}
                </div>
                {{ form_errors(form.email) }}
              </div>
              <div>
                <label class="block text-sm font-medium text-[#364153]">Téléphone</label>
                <div class="mt-2">
                  {{ form_widget(form.phone, {'attr': {'class': 'w-full rounded-md border border-[#D1D5DC] h-10 px-3 text-sm text-[#101828] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#EFF6FF] focus:border-[#155DFC]', 'placeholder': '+33 1 23 45 67 89'}}) }}
                </div>
                {{ form_errors(form.phone) }}
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-[#364153]">Adresse</label>
              <div class="mt-2">
                {{ form_widget(form.address, {'attr': {'class': 'w-full rounded-md border border-[#D1D5DC] h-24 px-3 py-2 text-sm text-[#101828] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#EFF6FF] focus:border-[#155DFC]', 'placeholder': '123 rue de la Paix, 75000 Paris'}}) }}
              </div>
              {{ form_errors(form.address) }}
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-[#364153]">SIRET (Optionnel)</label>
                <div class="mt-2">
                  {{ form_widget(form.siret, {'attr': {'class': 'w-full rounded-md border border-[#D1D5DC] h-10 px-3 text-sm text-[#101828] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#EFF6FF] focus:border-[#155DFC]', 'placeholder': '12345678901234'}}) }}
                </div>
                {{ form_errors(form.siret) }}
              </div>
              <div>
                <label class="block text-sm font-medium text-[#364153]">RIB (Optionnel)</label>
                <div class="mt-2">
                  {{ form_widget(form.rib, {'attr': {'class': 'w-full rounded-md border border-[#D1D5DC] h-10 px-3 text-sm text-[#101828] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#EFF6FF] focus:border-[#155DFC]', 'placeholder': 'Numéro de compte bancaire'}}) }}
                </div>
                {{ form_errors(form.rib) }}
              </div>
            </div>

            <div class="flex justify-end gap-3 mt-4">
              <a href="{{ path('client_index') }}" class="inline-flex items-center px-4 py-2 border border-[#D1D5DC] rounded-md text-sm text-[#364153] hover:bg-gray-50">Annuler</a>
              <button type="submit" class="inline-flex items-center px-4 py-2 bg-[#155DFC] text-white rounded-md text-sm hover:bg-[#1447E6]">Créer le client</button>
            </div>

          {{ form_end(form) }}
        </div>

        <h3 class="text-lg font-semibold text-[#101828]">Clients existants</h3>

        <!-- Clients table (desktop) -->
        <div class="hidden md:block overflow-x-auto w-full">
          <div class="bg-white overflow-hidden" style="min-width:780px; height:259px; min-height:200px; background:#FFFFFF; padding:0; border-width:1px; border-radius:14px; border-top:1px solid #F3F4F6; box-shadow:0px 1px 2px -1px rgba(0,0,0,0.102), 0px 1px 3px 0px rgba(0,0,0,0.102);">
            <div class="w-full flex flex-col h-full">
              <div class="bg-[#F9FAFB] rounded-t-[14px] border-b border-gray-200">
                <div class="items-center grid" style="grid-template-columns: 240px 340px 1fr 200px; height:48px;">
                  <div class="px-4 text-sm font-semibold text-[#101828]">Nom</div>
                  <div class="px-4 text-sm font-semibold text-[#101828]">Contact</div>
                  <div class="px-4 text-sm font-semibold text-[#101828]">Adresse</div>
                  <div class="px-4 text-sm font-semibold text-[#101828] text-right">Actions</div>
                </div>
              </div>
              <div class="flex-1 overflow-hidden">
                {% for client in clients %}
                  <div class="grid" style="grid-template-columns: 240px 340px 1fr 200px; border-bottom:1px solid #F3F4F6; background:#FFFFFF; height:48px; align-items:center;">
                    <div class="px-4 text-base text-[#101828] truncate">{{ client.name }}</div>
                    <div class="px-4">
                      <div class="text-sm text-[#4A5565] truncate">{{ client.email ?? '-' }}</div>
                      <div class="text-xs text-[#6A7282] mt-0.5">{{ client.phone ?? '-' }}</div>
                    </div>
                    <div class="px-4 text-sm text-[#101828] truncate">{{ client.address ?? '-' }}</div>
                    <div class="flex justify-end items-center gap-3 pr-4">
                      <a href="{{ path('client_edit', { id: client.id }) }}" class="inline-flex items-center text-[#155DFC] hover:text-[#1447E6]">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 21v-3.75L15.75 4.5l3.75 3.75L6.75 21H3z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </a>
                      <form method="post" action="{{ path('client_delete', { id: client.id }) }}" class="inline-block m-0" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce client ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
                        <button type="submit" class="inline-flex items-center text-[#E7000B] hover:text-red-600">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><polyline points="3 6 5 6 21 6" stroke-linecap="round" stroke-linejoin="round"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 11v6" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 11v6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </button>
                      </form>
                    </div>
                  </div>
                {% else %}
                  <div class="py-8 text-center text-[#6B7280]">Vous n'avez pas encore de clients.</div>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>

        <!-- Clients cards (mobile) -->
        <div class="md:hidden w-full flex flex-col gap-3">
          {% for client in clients %}
            <div class="bg-white rounded-xl border border-[#F3F4F6] p-4 shadow-sm">
              <div class="flex items-start justify-between">
                <div>
                  <div class="font-semibold text-[#101828]">{{ client.name }}</div>
                  <div class="text-sm text-[#4A5565] mt-0.5">{{ client.email ?? '-' }}</div>
                  <div class="text-xs text-[#6A7282]">{{ client.phone ?? '-' }}</div>
                  <div class="text-sm text-[#101828] mt-1">{{ client.address ?? '-' }}</div>
                </div>
                <div class="flex items-center gap-3 ml-4 shrink-0">
                  <a href="{{ path('client_edit', { id: client.id }) }}" class="inline-flex items-center text-[#155DFC] hover:text-[#1447E6]">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 21v-3.75L15.75 4.5l3.75 3.75L6.75 21H3z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                  <form method="post" action="{{ path('client_delete', { id: client.id }) }}" class="inline-block m-0" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce client ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
                    <button type="submit" class="inline-flex items-center text-[#E7000B] hover:text-red-600">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><polyline points="3 6 5 6 21 6" stroke-linecap="round" stroke-linejoin="round"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 11v6" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 11v6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                  </form>
                </div>
              </div>
            </div>
          {% else %}
            <div class="py-8 text-center text-[#6B7280]">Vous n'avez pas encore de clients.</div>
          {% endfor %}
        </div>
      </div>
    </section>
  </main>
{% endblock %}
