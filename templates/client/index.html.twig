{% extends 'base.html.twig' %}

{% block title %}Clients{% endblock %}

{% block body %}
  <div class="container">
    <h1>Clients</h1>

    <table class="table">
      <thead>
        <tr><th>Nom</th><th>Email</th><th>Téléphone</th><th></th></tr>
      </thead>
      <tbody>
        {% for c in clients %}
          <tr>
            <td>{{ c.name }}</td>
            <td>{{ c.email|default('-') }}</td>
            <td>{{ c.phone|default('-') }}</td>
            <td><a class="inline-flex items-center px-3 py-1.5 bg-gray-200 text-gray-800 rounded text-sm hover:bg-gray-300" href="#">Voir</a></td>
          </tr>
        {% else %}
          <tr><td colspan="4">Aucun client</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}
