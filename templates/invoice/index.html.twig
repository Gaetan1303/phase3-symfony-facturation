{% extends 'base.html.twig' %}

{% block title %}Factures{% endblock %}

{% block body %}
  <div class="min-h-screen bg-gray-50 p-8">
    <div class="mx-auto" style="max-width:1203px;">
      <div class="flex items-center justify-between mb-6" style="height:72px;">
        <div>
          <a href="{{ path('app_invoices') }}" class="text-sm text-gray-500 inline-flex items-center">← Retour aux factures</a>
          <h1 class="text-2xl font-bold mt-3">Factures</h1>
        </div>
        <a href="{{ path('invoice_new') }}" class="inline-flex items-center px-4 py-2 bg-[#155DFC] text-white rounded-md shadow">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          Créer une facture
        </a>
      </div>

      <div class="bg-white rounded-2xl shadow p-6 space-y-8">
        <div>
          <h3 class="text-lg font-semibold mb-3">En attente de paiement</h3>
          {% if pending is defined and pending is not empty %}
            <div class="overflow-x-auto">
              <table class="w-full border-collapse">
                <thead class="text-sm text-gray-600 border-b">
                  <tr style="height:52.5px;">
                    <th class="text-left pl-6">Numéro</th>
                    <th class="text-left px-6">Date</th>
                    <th class="text-left px-6">Client</th>
                    <th class="text-right px-6">Total TTC</th>
                    <th class="text-left px-6">Statut</th>
                    <th class="text-right pr-6">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white">
                  {% for inv in pending %}
                    <tr class="align-middle" style="height:48px;">
                      <td class="pl-6 text-base text-gray-800"><a href="{{ path('invoice_show', {id: inv.id}) }}" class="text-gray-800 hover:underline">{{ inv.number }}</a></td>
                      <td class="px-6 text-sm text-gray-500">{{ inv.createdAt|date('d/m/Y') }}</td>
                      <td class="px-6 text-base text-gray-800">{{ inv.client ? inv.client.name : '-' }}</td>
                      <td class="px-6 text-right text-base font-semibold text-gray-800">{{ inv.totalTtc }} €</td>
                      <td class="px-6">{% include 'components/status_badge.html.twig' with {'status': inv.status} %}</td>
                      <td class="pr-6 text-right text-sm"><a href="{{ path('invoice_show', {id: inv.id}) }}" class="text-[#155DFC]">Détails</a></td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% else %}
            <div class="py-6 text-sm text-gray-500">Aucune facture en attente.</div>
          {% endif %}
        </div>

        <div>
          <h3 class="text-lg font-semibold mb-3">Payées</h3>
          {% if paid is defined and paid is not empty %}
            <div class="overflow-x-auto">
              <table class="w-full border-collapse">
                <thead class="text-sm text-gray-600 border-b">
                  <tr style="height:52.5px;">
                    <th class="text-left pl-6">Numéro</th>
                    <th class="text-left px-6">Date</th>
                    <th class="text-left px-6">Client</th>
                    <th class="text-right px-6">Total TTC</th>
                    <th class="text-left px-6">Statut</th>
                    <th class="text-right pr-6">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white">
                  {% for inv in paid %}
                    <tr class="align-middle" style="height:48px;">
                      <td class="pl-6 text-base text-gray-800"><a href="{{ path('invoice_show', {id: inv.id}) }}" class="text-gray-800 hover:underline">{{ inv.number }}</a></td>
                      <td class="px-6 text-sm text-gray-500">{{ inv.createdAt|date('d/m/Y') }}</td>
                      <td class="px-6 text-base text-gray-800">{{ inv.client ? inv.client.name : '-' }}</td>
                      <td class="px-6 text-right text-base font-semibold text-gray-800">{{ inv.totalTtc }} €</td>
                      <td class="px-6">{% include 'components/status_badge.html.twig' with {'status': inv.status} %}</td>
                      <td class="pr-6 text-right text-sm"><a href="{{ path('invoice_show', {id: inv.id}) }}" class="text-[#155DFC]">Détails</a></td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% else %}
            <div class="py-6 text-sm text-gray-500">Aucune facture payée.</div>
          {% endif %}
        </div>

        <div>
          <h3 class="text-lg font-semibold mb-3">Brouillons</h3>
          {% if drafts is defined and drafts is not empty %}
            <div class="overflow-x-auto">
              <table class="w-full border-collapse">
                <thead class="text-sm text-gray-600 border-b">
                  <tr style="height:52.5px;">
                    <th class="text-left pl-6">Numéro</th>
                    <th class="text-left px-6">Date</th>
                    <th class="text-left px-6">Client</th>
                    <th class="text-right px-6">Total TTC</th>
                    <th class="text-left px-6">Statut</th>
                    <th class="text-right pr-6">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white">
                  {% for inv in drafts %}
                    <tr class="align-middle" style="height:48px;">
                      <td class="pl-6 text-base text-gray-800"><a href="{{ path('invoice_show', {id: inv.id}) }}" class="text-gray-800 hover:underline">{{ inv.number }}</a></td>
                      <td class="px-6 text-sm text-gray-500">{{ inv.createdAt|date('d/m/Y') }}</td>
                      <td class="px-6 text-base text-gray-800">{{ inv.client ? inv.client.name : '-' }}</td>
                      <td class="px-6 text-right text-base font-semibold text-gray-800">{{ inv.totalTtc }} €</td>
                      <td class="px-6">{% include 'components/status_badge.html.twig' with {'status': inv.status} %}</td>
                      <td class="pr-6 text-right text-sm">
                        <a href="{{ path('invoice_edit', {id: inv.id}) }}" class="text-[#155DFC] mr-4">Modifier</a>
                        <form method="post" action="{{ path('invoice_delete', { id: inv.id }) }}" class="inline-block" data-turbo="false">
                          <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inv.id) }}">
                          <button type="button" class="text-[#E7000B]" data-action="confirm#open" data-confirm-message="Supprimer la facture {{ inv.number }} ?">Supprimer</button>
                        </form>
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% else %}
            <div class="py-6 text-sm text-gray-500">Aucun brouillon.</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endblock %}
