{% extends 'base.html.twig' %}

{% block title %}Factures{% endblock %}

{% block body %}
  <div class="min-h-screen bg-gray-50 p-8">
    <div class="mx-auto" style="max-width:1203px;">
      <div class="flex items-center justify-between mb-6" style="height:72px;">
        <div>
          <a href="{{ path('app_invoices') }}" class="text-sm text-gray-500 inline-flex items-center">← Retour aux factures</a>
          <h1 class="text-2xl font-bold mt-3">Factures</h1>
        </div>
        <a href="{{ path('invoice_new') }}" class="inline-flex items-center px-4 py-2 bg-[#155DFC] text-white rounded-md shadow">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          Créer une facture
        </a>
      </div>

      <div class="bg-white rounded-2xl shadow p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <button class="px-4 py-2 bg-[#EFF6FF] text-[#1447E6] rounded-full text-sm">Toutes</button>
            <button class="px-4 py-2 bg-white border border-gray-100 rounded-full text-sm">Brouillons</button>
            <button class="px-4 py-2 bg-white border border-gray-100 rounded-full text-sm">En attente</button>
            <button class="px-4 py-2 bg-white border border-gray-100 rounded-full text-sm">Payées</button>
          </div>
          <div class="text-sm text-gray-500">&nbsp;</div>
        </div>

        <div class="w-full overflow-hidden">
          <table class="w-full border-collapse">
            <thead class="text-sm text-gray-600 border-b">
              <tr style="height:52.5px;">
                <th class="text-left pl-6">Numéro</th>
                <th class="text-left px-6">Date</th>
                <th class="text-left px-6">Client</th>
                <th class="text-right px-6">Total TTC</th>
                <th class="text-left px-6">Statut</th>
                <th class="text-right pr-6">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white">
              {% for inv in invoices %}
                <tr class="align-middle" style="height:48px;">
                  <td class="pl-6 text-base text-gray-800">{{ inv.number }}</td>
                  <td class="px-6 text-sm text-gray-500">{{ inv.createdAt|date('d/m/Y') }}</td>
                  <td class="px-6 text-base text-gray-800">{{ inv.client ? inv.client.name : '-' }}</td>
                  <td class="px-6 text-right text-base font-semibold text-gray-800">{{ inv.totalTtc }} €</td>
                  <td class="px-6">
                    {% if inv.status == constant('App\\Enum\\InvoiceStatus::PAID') %}
                      <span class="inline-block bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm">Payée</span>
                    {% elseif inv.status == constant('App\\Enum\\InvoiceStatus::PENDING_PAYMENT') %}
                      <span class="inline-block bg-yellow-50 text-yellow-700 px-3 py-1 rounded-full text-sm">En attente</span>
                    {% else %}
                      <span class="inline-block bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm">Brouillon</span>
                    {% endif %}
                  </td>
                  <td class="pr-6 text-right text-sm">
                    {% if inv.status == constant('App\\Enum\\InvoiceStatus::DRAFT') %}
                      <a href="{{ path('invoice_edit', {id: inv.id}) }}" class="text-[#155DFC] mr-4">Modifier</a>
                      <form method="post" action="{{ path('invoice_delete', { id: inv.id }) }}" class="inline-block" onsubmit="return confirm('Supprimer cette facture ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inv.id) }}">
                        <button type="submit" class="text-[#E7000B]">Supprimer</button>
                      </form>
                    {% else %}
                      <a href="#" class="text-[#155DFC]">Détails</a>
                    {% endif %}
                  </td>
                </tr>
              {% else %}
                <tr><td colspan="6" class="py-12 text-center text-gray-500">Aucune facture</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
