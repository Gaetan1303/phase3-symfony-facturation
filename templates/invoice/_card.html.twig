<div class="bg-white rounded-2xl shadow p-6 mt-4">
  <div class="flex items-center justify-between mb-6">
    <div>
      <div class="text-sm text-gray-500">Numéro</div>
      <h2 class="text-2xl font-bold">{{ invoice.number }}</h2>
      <div class="text-sm text-gray-500">{{ invoice.createdAt ? invoice.createdAt|date('d/m/Y') : '-' }}</div>
    </div>
    <div class="flex items-center gap-3">
      {% if invoice.status.value == 'pending_payment' %}
        <form method="post" action="{{ path('invoice_generate_pdf', {id: invoice.id}) }}" class="inline">
          <input type="hidden" name="_token" value="{{ csrf_token('generate_pdf' ~ invoice.id) }}">
          <button type="submit" class="inline-flex items-center px-4 py-2 bg-[#155DFC] text-white rounded-md text-sm">Générer PDF</button>
        </form>

        {# Mark as paid form with confirmation #}
        <form method="post" action="{{ path('invoice_mark_paid', {id: invoice.id}) }}" class="inline" data-turbo="true" onsubmit="return confirm('Confirmer : marquer cette facture comme payée ?');">
          <input type="hidden" name="_token" value="{{ csrf_token('mark_paid' ~ invoice.id) }}">
          <button type="submit" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-md text-sm">Marquer comme payée</button>
        </form>
      {% endif %}

      {% if invoice.pdfPath %}
        <a href="{{ path('invoice_download', {id: invoice.id}) }}" target="_blank" class="inline-flex items-center px-4 py-2 bg-gray-100 rounded-md text-sm">Télécharger PDF</a>
      {% endif %}
      <a href="{{ path('invoice_pdf', {id: invoice.id}) }}" target="_blank" class="inline-flex items-center px-4 py-2 bg-gray-100 rounded-md text-sm">Aperçu PDF</a>
    </div>
    <div class="text-right">
      {% include 'components/status_badge.html.twig' with {'status': invoice.status} %}
      <div class="text-sm text-gray-500">Total TTC</div>
      <div class="text-2xl font-semibold">{{ invoice.totalTtc }} €</div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-6 mb-6">
    <div>
      <h3 class="font-semibold">Client</h3>
      <div class="text-base">{{ invoice.client ? invoice.client.name : '-' }}</div>
      <div class="text-sm text-gray-500">{{ invoice.client ? invoice.client.email : '' }}</div>
    </div>
    <div>
      <h3 class="font-semibold">Adresse</h3>
      <div class="text-sm text-gray-700">{{ invoice.client ? invoice.client.address : '-' }}</div>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-left">
      <thead class="text-sm text-gray-500 border-b">
        <tr>
          <th class="py-2">Produit / Service</th>
          <th class="py-2">Quantité</th>
          <th class="py-2">Prix unitaire</th>
          <th class="py-2 text-right">Total</th>
        </tr>
      </thead>
      <tbody>
        {% for line in invoice.lines %}
          <tr class="border-b">
            <td class="py-3">{{ line.label }}</td>
            <td class="py-3">{{ line.quantity }}</td>
            <td class="py-3">{{ line.unitPrice }} €</td>
            <td class="py-3 text-right">{{ line.getLineTotal() }} €</td>
          </tr>
        {% else %}
          <tr><td colspan="4" class="py-8 text-center text-gray-500">Aucune ligne</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
