<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Facture {{ invoice.number }}</title>
    <style>
      body { font-family: Arial, Helvetica, sans-serif; color:#222; font-size:12px; }
      .header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px }
      .client { margin-top:12px }
      table { width:100%; border-collapse:collapse; margin-top:18px }
      th, td { padding:8px 6px; border-bottom:1px solid #e5e7eb }
      th { text-align:left; background:#f8fafc }
      .text-right { text-align:right }
      .total { font-size:16px; font-weight:600; margin-top:12px }
    </style>
  </head>
  <body>
    <div class="header">
      <div>
        <h1>Facture {{ invoice.number }}</h1>
        <div>{{ invoice.createdAt ? invoice.createdAt|date('d/m/Y') : '-' }}</div>
      </div>
      <div class="text-right">
        <div>Statut : {{ invoice.status.value }}</div>
        <div class="total">Total TTC: {{ invoice.totalTtc }} €</div>
      </div>
    </div>

    <div class="client">
      <strong>Client</strong>
      <div>{{ invoice.client ? invoice.client.name : '-' }}</div>
      <div>{{ invoice.client ? invoice.client.address : '' }}</div>
      <div>{{ invoice.client ? invoice.client.email : '' }}</div>
    </div>

    <table>
      <thead>
        <tr>
          <th>Produit / Service</th>
          <th>Qté</th>
          <th>PU</th>
          <th class="text-right">Total</th>
        </tr>
      </thead>
      <tbody>
        {% for line in invoice.lines %}
          <tr>
            <td>{{ line.label }}</td>
            <td>{{ line.quantity }}</td>
            <td>{{ line.unitPrice }} €</td>
            <td class="text-right">{{ line.getLineTotal() }} €</td>
          </tr>
        {% else %}
          <tr><td colspan="4" class="text-center">Aucune ligne</td></tr>
        {% endfor %}
      </tbody>
    </table>
    <div style="margin-top:24px; font-size:11px; color:#555; border-top:1px solid #ddd; padding-top:12px;">
      <strong>Conditions générales de vente (CGV)</strong>
      {% if invoice.user and invoice.user.cgv %}
        <p style="font-style:italic; margin:6px 0;">* {{ invoice.user.cgv|raw }}</p>
      {% else %}
        <p style="font-style:italic; margin:6px 0;">* Les prestations sont réalisées selon les conditions générales de vente de la société. Toute réclamation doit être faite dans les 7 jours suivant réception.</p>
      {% endif %}

      <p style="font-style:italic; margin:6px 0;">* <strong>SIRET :</strong> {{ invoice.user ? invoice.user.siret|default('-') : '-' }}</p>
      <p style="font-style:italic; margin:6px 0;">* <strong>Conditions de paiement :</strong> {{ invoice.user ? (invoice.user.paymentTerms|default('Paiement à 30 jours fin de mois, par virement bancaire. Retard de paiement soumis aux pénalités légales.')) : 'Paiement à 30 jours fin de mois, par virement bancaire. Retard de paiement soumis aux pénalités légales.' }}</p>
    </div>
  </body>
</html>
