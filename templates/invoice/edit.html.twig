{% extends 'base.html.twig' %}

{% block title %}Modifier facture {{ invoice.number }}{% endblock %}

{% block stylesheets %}
  <script src="https://cdn.tailwindcss.com"></script>
{% endblock %}

{% block body %}


    
    <section class="flex-1 p-8">
      <div class="mx-auto" style="width:896px;">
        <a href="{{ path('app_invoices') }}" class="text-sm text-gray-500 inline-flex items-center mb-4">← Retour aux factures</a>
        <h1 class="text-2xl font-bold mb-6">Modifier la facture {{ invoice.number ?: '' }}</h1>

        {% include 'invoice/_form_fragment.html.twig' with {'form': form, 'invoice': invoice} %}
      </div>
    </section>

  {# Inline JS removed — behavior handled by Stimulus controller `invoice-lines` in assets/controllers/invoice_lines_controller.js #}
{% endblock %}
