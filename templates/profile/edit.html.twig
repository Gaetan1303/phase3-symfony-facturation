{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block stylesheets %}
  <script src="https://cdn.tailwindcss.com"></script>
{% endblock %}

{% block body %}
  <main class="min-h-screen bg-gray-50 flex">
    <!-- Sidebar (light copy of dashboard sidebar) -->
    <aside class="w-64 bg-white border-r border-gray-200 hidden md:flex md:flex-col box-border h-screen">
      <div class="p-6 flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" aria-hidden="true">
            <path d="M4.66667 2.33333V25.6667L7 24.5L9.33333 25.6667L11.6667 24.5L14 25.6667L16.3333 24.5L18.6667 25.6667L21 24.5L23.3333 25.6667V2.33333L21 3.5L18.6667 2.33333L16.3333 3.5L14 2.33333L11.6667 3.5L9.33333 2.33333L7 3.5L4.66667 2.33333Z" stroke="currentColor" stroke-width="2.33333" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M18.6667 9.33333H11.6667C11.0478 9.33333 10.4543 9.57917 10.0168 10.0168C9.57917 10.4543 9.33333 11.0478 9.33333 11.6667C9.33333 12.2855 9.57917 12.879 10.0168 13.3166C10.4543 13.7542 11.0478 14 11.6667 14H16.3333C16.9522 14 17.5457 14.2458 17.9832 14.6834C18.4208 15.121 18.6667 15.7145 18.6667 16.3333C18.6667 16.9522 18.4208 17.5457 17.9832 17.9832C17.5457 18.4208 16.9522 18.6667 16.3333 18.6667H9.33333" stroke="currentColor" stroke-width="2.33333" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M14 20.4167V7.58333" stroke="currentColor" stroke-width="2.33333" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="text-lg font-semibold text-blue-700">FacturSaaS</div>
      </div>

      <nav class="px-4 py-6 space-y-3 flex-1">
        <a href="{{ path('app_dashboard') }}" class="flex items-center gap-3 px-4 h-11 w-56 rounded-[10px] text-sm font-medium bg-[#EFF6FF] text-[#1447E6]">Dashboard</a>
        <a href="{{ path('app_invoices') }}" class="flex items-center gap-3 px-4 h-11 w-56 rounded-[10px] text-sm text-gray-700 hover:bg-gray-50">Factures</a>
        <a href="{{ path('client_index') }}" class="flex items-center gap-3 px-4 h-11 w-56 rounded-[10px] text-sm text-gray-700 hover:bg-gray-50">Clients</a>
        <a href="{{ path('product_index') }}" class="flex items-center gap-3 px-4 h-11 w-56 rounded-[10px] text-sm text-gray-700 hover:bg-gray-50">Produits</a>
        <a href="{{ path('user_profile') }}" class="flex items-center gap-3 px-4 h-11 w-56 rounded-[10px] text-sm text-gray-700 hover:bg-gray-50">Profil</a>
        <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-4 h-11 w-56 rounded-[10px] text-sm text-gray-700 hover:bg-gray-50">Déconnexion</a>
      </nav>

      <div class="p-4 border-t border-gray-100">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center font-medium text-gray-700">{{ ((app.user.firstName|default('J')|slice(0,1)) ~ (app.user.lastName|default('D')|slice(0,1)))|upper }}</div>
          <div class="flex-1">
            <div class="text-sm font-medium text-gray-900">{{ app.user.companyName|default('Tech Solutions') }}</div>
            <div class="text-xs text-gray-500">{{ app.user.email|default('contact@entreprise.fr') }}</div>
          </div>
        </div>
        <div class="mt-3">
          <a href="{{ path('app_logout') }}" class="flex items-center gap-2 text-sm text-red-600 hover:text-red-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Déconnexion
          </a>
        </div>
      </div>
    </aside>

    <!-- Profile content -->
    <section class="flex-1 p-8">
      <div class="max-w-2xl mx-auto">
        <h1 class="text-2xl font-bold text-gray-900 mb-6">Mon profil</h1>

        <div class="bg-white rounded-[10px] border border-gray-100 p-6 max-w-[672px] shadow-[0_1px_2px_rgba(0,0,0,0.1),0_1px_3px_rgba(0,0,0,0.1)]">
          {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

            <div>
              <label class="block text-sm font-medium text-gray-700">Raison sociale</label>
              <div class="mt-1">
                {{ form_widget(form.companyName, {'attr': {'class': 'block w-full rounded-md border border-gray-200 h-11 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500'}}) }}
              </div>
              <p class="mt-2 text-sm text-gray-500 flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="16" x2="12" y2="12"></line>
                  <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
                <span>Le nom de votre entreprise qui apparaîtra sur vos factures.</span>
              </p>
              {{ form_errors(form.companyName) }}
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">SIRET (optionnel)</label>
              <div class="mt-1">
                {{ form_widget(form.siret, {'attr': {'class': 'block w-full rounded-md border border-gray-200 h-11 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500'}}) }}
              </div>
              {{ form_errors(form.siret) }}
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">IBAN</label>
              <div class="mt-1">
                {{ form_widget(form.iban, {'attr': {'class': 'block w-full rounded-md border border-gray-200 h-11 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500'}}) }}
              </div>
              <p class="mt-2 text-sm text-gray-500 flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="16" x2="12" y2="12"></line>
                  <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
                <span>Compte bancaire qui recevra les virements de vos clients.</span>
              </p>
              {{ form_errors(form.iban) }}
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Conditions Générales de Vente (CGV)</label>
              <div class="mt-1">
                {{ form_widget(form.cgv, {'attr': {'class': 'block w-full rounded-md border border-gray-200 h-28 p-3 text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500'}}) }}
              </div>
              <p class="mt-2 text-sm text-gray-500 flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="16" x2="12" y2="12"></line>
                  <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
                <span>Ces conditions seront affichées au bas de vos factures PDF.</span>
              </p>
              {{ form_errors(form.cgv) }}
            </div>

            <div class="flex items-center gap-3">
              <button type="submit" class="inline-flex items-center px-4 py-2 bg-[#1366FF] text-white rounded-md shadow-sm hover:bg-[#0f57d9]">Enregistrer les modifications</button>
              <a href="{{ path('app_dashboard') }}" class="text-sm text-gray-600">Annuler</a>
            </div>

          {{ form_end(form) }}
        </div>
      </div>
    </section>
  </main>
{% endblock %}
