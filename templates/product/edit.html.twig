{% extends 'base.html.twig' %}

{% block title %}Modifier produit{% endblock %}

{% block body %}
  <div class="min-h-screen bg-gray-50 p-8">
    <div class="mx-auto" style="max-width:900px;">
      <a href="{{ path('product_index') }}" class="text-sm text-gray-500 inline-flex items-center">← Retour</a>
      <div class="bg-white rounded-2xl shadow p-6 mt-4">
        <h2 class="text-xl font-semibold mb-4">Modifier le produit</h2>

        {% for type, messages in app.flashes %}
          {% for message in messages %}
            <div class="mb-4 p-4 rounded-md {% if type == 'success' %}bg-green-50 text-green-800 border border-green-200{% else %}bg-red-50 text-red-800 border border-red-200{% endif %}">{{ message }}</div>
          {% endfor %}
        {% endfor %}

        {{ form_start(form) }}
          <div class="grid grid-cols-1 gap-4">
            <div>
              {{ form_row(form.name) }}
            </div>
            <div>
              {{ form_row(form.description) }}
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>{{ form_row(form.price) }}</div>
              <div>{{ form_row(form.unit) }}</div>
            </div>
            <div class="pt-4">
              <button type="submit" class="px-4 py-2 bg-[#155DFC] text-white rounded-md">Enregistrer</button>
            </div>
          </div>
        {{ form_end(form) }}
      </div>
    </div>
  </div>
{% endblock %}
