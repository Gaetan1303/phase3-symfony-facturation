{% extends 'base.html.twig' %}

{% block title %}Nouveau produit{% endblock %}

{% block body %}
      <!-- Main content -->
      <main class="flex-1 p-8">
        <div class="max-w-6xl mx-auto">
          <div class="flex justify-center">
            <div class="w-full max-w-2xl">
              <a href="{{ path('product_index') }}" class="text-sm text-gray-500 inline-flex items-center">← Retour</a>
              <h1 class="text-3xl font-extrabold text-[#101828] uppercase mt-6 tracking-wide">Ajouter un nouveau produit</h1>

              {% for type, messages in app.flashes %}
                {% for message in messages %}
                  <div class="mb-4 p-4 rounded-md {% if type == 'success' %}bg-green-50 text-green-800 border border-green-200{% else %}bg-red-50 text-red-800 border border-red-200{% endif %}">{{ message }}</div>
                {% endfor %}
              {% endfor %}

              <div class="mt-8 relative">
                <div class="bg-white rounded-2xl shadow-lg p-8">
                  <h2 class="text-lg font-semibold mb-6">Nouveau produit</h2>

                  {{ form_start(form) }}

                    {# Lines container inspired by add_product_card: header + list of rows #}
                    <div class="mt-2">
                      <div class="bg-[#F9FAFB] border border-[#E5E7EB] rounded-lg p-4">
                        <div class="grid grid-cols-[1fr_6rem_9rem_8rem] gap-4 items-center text-sm text-[#6B7280] mb-3 px-2">
                          <div class="pl-2">Produit</div>
                          <div class="text-center">Quantité</div>
                          <div class="text-right">Prix unitaire (€)</div>
                          <div class="text-right">Total</div>
                        </div>

                        <div class="space-y-3">
                          {% set qty_field_html = (form.quantity is defined) ? form_row(form.quantity) : '' %}
                          {% include 'components/add_product_card.html.twig' with {
                            label_field: form_row(form.name),
                            price_field: form_row(form.price),
                            qty_field: qty_field_html,
                            show_add_button: true
                          } %}
                        </div>
                      </div>
                    </div>

                    <div class="mt-6 space-y-4">
                      <div>{{ form_row(form.description) }}</div>
                      <div class="w-48">{{ form_row(form.unit) }}</div>
                    </div>

                    <div class="mt-6 flex justify-end gap-3">
                      <a href="{{ path('product_index') }}" class="px-4 py-2 border rounded-md text-[#364153]">Annuler</a>
                      <button type="submit" class="px-4 py-2 bg-[#155DFC] text-white rounded-md">Créer</button>
                    </div>
                  {{ form_end(form) }}
                </div>

                <!-- Floating total box to match mockup -->
                <div class="absolute" style="right:-220px; top:72px;">
                  <div class="bg-white rounded-md shadow-md px-5 py-4 text-sm text-center border">
                    <div class="text-gray-500">Total</div>
                    <div class="text-[#155DFC] font-bold text-lg">0.00 €</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
{% endblock %}
