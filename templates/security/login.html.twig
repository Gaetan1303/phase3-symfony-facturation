{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block stylesheets %}
    {% include 'components/_styles.html.twig' %}
  {% include 'components/_register_styles.html.twig' %}
  {% include 'components/_login_styles.html.twig' %}
{% endblock %}

{% block body %}
  {% include 'components/_header.html.twig' %}

  <main class="login-page">
    <div class="login-container">
      <section class="login-card" aria-label="Se connecter">
        <div class="login-header">
          <div class="login-title">Se connecter</div>
        </div>

        <form method="post" action="{{ path('app_login') }}" class="login-form">
          {% if error %}
            <div class="form-group"><div class="form-input" style="border-color:#f43f5e;color:#b91c1c">{{ error.messageKey|trans(error.messageData, 'security') }}</div></div>
          {% endif %}

          <div class="form-group">
            <label class="form-label" for="email">Adresse e‑mail</label>
            <div class="form-input"><input type="email" id="email" name="email" value="{{ last_username }}" required autofocus></div>
          </div>

          <div class="form-group">
            <label class="form-label" for="password">Mot de passe</label>
            <div class="form-input"><input type="password" id="password" name="password" required></div>
          </div>

          <div style="margin-top:16px; text-align:center;">
            <button type="submit" class="btn-primary">Se connecter</button>
          </div>
        </form>

      </section>
    </div>
  </main>
{% endblock %}
